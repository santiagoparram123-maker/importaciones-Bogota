# ==========================================
# .gitignore — Proyecto SaaS: Importaciones Bogotá
# ==========================================

# ── 1. Datasets y archivos de datos pesados ──
*.csv
*.xlsx
*.xlsb
*.xls

# ── 2. Outputs generados (legacy) ──
graficos_output/
reporte_importaciones.html

# ── 3. Entornos virtuales y secretos ──
.env
.env.*
.venv/
venv/
env/

# ── 4. Caché y bytecode de Python ──
__pycache__/
*.pyc
*.pyo
*.pyd

# ── 5. Asistentes de IA y herramientas ──
.aider*
.claude/
.gemini/
.cursor/
.copilot/

# ── 6. Experimentos y pruebas pasadas ──
*baloto*
*prueba*
*test_scratch*
experiments/

# ── 7. Sistema operativo ──
.DS_Store
Thumbs.db
desktop.ini

# ── 8. IDEs y editores ──
.vscode/
.idea/
*.swp
*.swo
*~
